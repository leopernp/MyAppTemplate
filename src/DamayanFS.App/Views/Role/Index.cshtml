@model DamayanFS.App.ViewModels.Role.RoleIndexViewModel

@await Component.InvokeAsync("PageHeader", Model.PageHeader)

<div id="pagePermissions"
     data-can-create="@Model.CanCreate.ToString().ToLower()"
     data-can-update="@Model.CanUpdate.ToString().ToLower()"
     data-can-delete="@Model.CanDelete.ToString().ToLower()"
     style="display:none;"></div>

<div class="d-flex justify-content-between align-items-center mb-2">
    <button type="button" class="btn btn-sm btn-outline-secondary" id="btnRefreshRoles">
        <i class="bi bi-arrow-clockwise"></i> Refresh
    </button>
    <div class="input-group input-group-sm" style="max-width: 260px;">
        <span class="input-group-text border-end-0 bg-transparent"><i class="bi bi-search text-muted"></i></span>
        <input type="text" class="form-control border-start-0" id="tableRolesSearch" placeholder="Search roles...">
    </div>
</div>

<div class="table-responsive">
    <table class="table table-hover" id="tableRoles">
        <thead>
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Active</th>
                <th>Created By</th>
                <th>Created At</th>
                <th>Modified By</th>
                <th>Modified At</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody></tbody>
    </table>
</div>

<!-- Edit Role Modal -->
<div class="modal fade" id="modalEditRole" tabindex="-1" aria-labelledby="modalEditRoleLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title" id="modalEditRoleLabel">Edit Role</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="formEditRole" novalidate>
                    <input type="hidden" asp-for="Role.Id" />
                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Role.Name" class="form-label form-label-sm"></label>
                            <input asp-for="Role.Name" class="form-control form-control-sm" />
                        </div>
                        <div class="col-12">
                            <label asp-for="Role.Description" class="form-label form-label-sm"></label>
                            <textarea asp-for="Role.Description" class="form-control form-control-sm" rows="3"></textarea>
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input asp-for="Role.IsActive" class="form-check-input" role="switch" />
                                <label asp-for="Role.IsActive" class="form-check-label small"></label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-sm btn-primary" id="btnSaveRole">Save Changes</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/Utilities/datatables-helper.js" asp-append-version="true"></script>

    <script src="~/js/Settings/Role/RoleIndexScript.js" asp-append-version="true"></script>
}
