@model DamayanFS.App.ViewModels.Module.ModuleIndexViewModel

<style>
    /* Ensure icon picker modal is above the edit module modal */
    #modalIconPicker.show {
        z-index: 1061 !important;
    }
</style>

@await Component.InvokeAsync("PageHeader", Model.PageHeader)

<div id="pagePermissions"
     data-can-create="@Model.CanCreate.ToString().ToLower()"
     data-can-update="@Model.CanUpdate.ToString().ToLower()"
     data-can-delete="@Model.CanDelete.ToString().ToLower()"
     style="display:none;"></div>

<div class="d-flex justify-content-between align-items-center mb-2">
    <button type="button" class="btn btn-sm btn-outline-secondary" id="btnRefreshModules">
        <i class="bi bi-arrow-clockwise"></i> Refresh
    </button>
    <div class="input-group input-group-sm" style="max-width: 260px;">
        <span class="input-group-text border-end-0 bg-transparent"><i class="bi bi-search text-muted"></i></span>
        <input type="text" class="form-control border-start-0" id="tableModulesSearch" placeholder="Search modules...">
    </div>
</div>

<div class="table-responsive">
    <table class="table table-hover" id="tableModules">
        <thead>
            <tr>
                <th>Name</th>
                <th>Module Type</th>
                <th>Parent Module</th>
                <th>Controller</th>
                <th>Action</th>
                <th>Order</th>
                <th>Active</th>
                <th>Maintenance</th>
                <th>Created By</th>
                <th>Created At</th>
                <th>Modified By</th>
                <th>Modified At</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody></tbody>
    </table>
</div>

<!-- Edit Module Modal -->
<div class="modal fade" id="modalEditModule" tabindex="-1" aria-labelledby="modalEditModuleLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title" id="modalEditModuleLabel">Edit Module</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="formEditModule" novalidate>
                    <input type="hidden" asp-for="Module.Id" />
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label asp-for="Module.Name" class="form-label form-label-sm"></label>
                            <input asp-for="Module.Name" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Module.DisplayOrder" class="form-label form-label-sm"></label>
                            <input asp-for="Module.DisplayOrder" type="number" class="form-control form-control-sm" min="0" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Module.ModuleTypeId" class="form-label form-label-sm"></label>
                            <select asp-for="Module.ModuleTypeId" id="Module_ModuleTypeId" class="form-select form-select-sm tomselect-remote"
                                data-url="/ModuleType/Inquire"
                                data-placeholder="Select Module Type">
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Module.ParentModuleId" class="form-label form-label-sm"></label>
                            <select asp-for="Module.ParentModuleId" id="Module_ParentModuleId" class="form-select form-select-sm tomselect-remote"
                                data-url="/Module/GetAvailableParentModules"
                                data-placeholder="No Parent (Root)">
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Module.Controller" class="form-label form-label-sm"></label>
                            <input asp-for="Module.Controller" class="form-control form-control-sm" placeholder="e.g. Home" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Module.Action" class="form-label form-label-sm"></label>
                            <input asp-for="Module.Action" class="form-control form-control-sm" placeholder="e.g. Index" />
                        </div>
                        <div class="col-12">
                            <label asp-for="Module.Description" class="form-label form-label-sm"></label>
                            <textarea asp-for="Module.Description" class="form-control form-control-sm" rows="3"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Module.Icon" class="form-label form-label-sm"></label>
                            <div class="input-group input-group-sm">
                                <span class="input-group-text" id="iconPreview"><i id="iconPreviewEl" class="bi bi-diagram-3"></i></span>
                                <input asp-for="Module.Icon" class="form-control form-control-sm" id="Module_Icon" placeholder="e.g. bi bi-diagram-3" />
                                <button type="button" class="btn btn-outline-secondary" id="btnIconPicker" title="Pick an icon">
                                    <i class="bi bi-palette"></i>
                                </button>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-check form-switch mt-4">
                                <input asp-for="Module.IsActive" class="form-check-input" role="switch" />
                                <label asp-for="Module.IsActive" class="form-check-label small"></label>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-check form-switch mt-4">
                                <input asp-for="Module.InMaintenance" class="form-check-input" role="switch" />
                                <label asp-for="Module.InMaintenance" class="form-check-label small"></label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-sm btn-primary" id="btnSaveModule">Save Changes</button>
            </div>
        </div>
    </div>
</div>

<!-- Icon Picker Modal -->
<div class="modal fade" id="modalIconPicker" tabindex="-1" aria-labelledby="modalIconPickerLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title" id="modalIconPickerLabel">Select Icon</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <input type="text" class="form-control form-control-sm" id="iconSearchInput" placeholder="Search icons...">
                </div>
                <div id="iconPickerGrid" class="d-grid gap-2" style="grid-template-columns: repeat(auto-fill, minmax(50px, 1fr));">
                    <!-- Icons will be populated by JavaScript -->
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/Utilities/datatables-helper.js" asp-append-version="true"></script>
    <script src="~/js/Utilities/tomselect-helper.js" asp-append-version="true"></script>

    <script src="~/js/Settings/Module/ModuleIndexScript.js" asp-append-version="true"></script>
}
