@using System.Security.Claims

<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Finance System</title>

    <script src="~/themeAssets/js/admintemplate.js" asp-append-version="true"></script>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <script type="importmap"></script>

    <link rel="stylesheet" href="~/frontend-lib/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/frontend-lib/bootstrap-icons/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/frontend-lib/datatables.net-bs5/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="~/frontend-lib/datatables.net-buttons-bs5/buttons.bootstrap5.min.css" />

    <link rel="stylesheet" href="~/frontend-lib/sweetalert2/sweetalert2.min.css" />

    <link rel="stylesheet" href="~/frontend-lib/tom-select/dist/css/tom-select.bootstrap5.min.css" />
    <link rel="stylesheet" href="~/themeAssets/css/admintemplate.tomselect.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DamayanFS.App.styles.css" asp-append-version="true" />
    <!-- Template CSS -->
    <link rel="stylesheet" href="~/themeAssets/css/admintemplate.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/themeAssets/css/admintemplate.sweetalert.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/themeAssets/css/admintemplate.datatables.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="app-shell">
        <div id="userPageMeta"
             data-current-user-id="@User.FindFirstValue(ClaimTypes.NameIdentifier)"></div>


        @await Component.InvokeAsync("Sidebar")

        @await Html.PartialAsync("Layouts/_Topbar")


        <!-- ══════════ MAIN ══════════ -->
        <main class="main-content" id="mainContent" role="main">

            @if (TempData["SuccessMessage"] is string successMsg)
            {
                <div class="alert alert-success alert-dismissible fade show mb-4 d-flex align-items-center gap-2">
                    <i class="bi bi-check-circle-fill"></i><span>@successMsg</span>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] is string errorMsg)
            {
                <div class="alert alert-danger alert-dismissible fade show mb-4 d-flex align-items-center gap-2">
                    <i class="bi bi-exclamation-circle-fill"></i><span>@errorMsg</span>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @Html.AntiForgeryToken()

        @RenderBody()

        </main>
    </div>

    <script src="~/frontend-lib/jquery/jquery.min.js"></script>
    <script src="~/frontend-lib/bootstrap/js/bootstrap.bundle.min.js"></script>
    <!-- SignalR -->
    <script src="~/frontend-lib/microsoft/signalr/dist/browser/signalr.min.js"></script>

    <script src="~/frontend-lib/datatables.net/dataTables.min.js"></script>
    <script src="~/frontend-lib/datatables.net-bs5/dataTables.bootstrap5.min.js"></script>

    <script src="~/frontend-lib/jszip/jszip.min.js"></script>
    <script src="~/frontend-lib/pdfmake/pdfmake.min.js"></script>
    <script src="~/frontend-lib/pdfmake/vfs_fonts.js"></script>

    <script src="~/frontend-lib/datatables.net-buttons/js/dataTables.buttons.min.js"></script>
    <script src="~/frontend-lib/datatables.net-buttons-bs5/buttons.bootstrap5.min.js"></script>
    <script src="~/frontend-lib/datatables.net-buttons/js/buttons.html5.min.js"></script>
    <script src="~/frontend-lib/datatables.net-buttons/js/buttons.print.min.js"></script>

    <script src="~/frontend-lib/moment.js/moment.min.js"></script>
    <script src="~/frontend-lib/tom-select/dist/js/tom-select.complete.min.js"></script>

    <script src="~/frontend-lib/sweetalert2/sweetalert2.all.min.js"></script>
    <script src="~/js/Utilities/app-notifications.js" asp-append-version="true"></script>

    <script src="~/js/Utilities/global-functions.js" asp-append-version="true"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/themeAssets/js/admintemplate.app.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
