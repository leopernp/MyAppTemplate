@model MyAppTemplate.App.ViewModels.Permission.PermissionRoleViewModel

<style>
    .perm-matrix th, .perm-matrix td { vertical-align: middle; }
    .perm-matrix .col-perm { width: 60px; text-align: center; }
    .perm-matrix .col-actions { width: 90px; text-align: center; }
    .perm-row-active { background-color: rgba(var(--bs-success-rgb), 0.07) !important; }
    .perm-type-header td { background-color: var(--bs-secondary-bg); font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }
    .perm-check { cursor: pointer; width: 1.1rem; height: 1.1rem; }
</style>

@await Component.InvokeAsync("PageHeader", Model.PageHeader)

<div id="pageMeta"
     data-role-id="@Model.RoleId"
     data-role-name="@Model.RoleName">
</div>

<div class="d-flex justify-content-between align-items-center mb-2">
    <div class="d-flex gap-2 align-items-center">
        <button type="button" class="btn btn-sm btn-outline-secondary" id="btnRefresh">
            <i class="bi bi-arrow-clockwise"></i> Refresh
        </button>
        <div style="min-width:220px;">
            <select id="roleSelector" class="form-select form-select-sm"
                    data-placeholder="Switch role..."></select>
        </div>
    </div>
    <div class="d-flex gap-2 align-items-center">
        <span class="badge bg-success-subtle text-success border border-success-subtle">
            <i class="bi bi-shield-check me-1"></i>Has Permissions
        </span>
        <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle">
            <i class="bi bi-diagram-3 me-1"></i>Group Node
        </span>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-hover perm-matrix" id="tablePermissions">
        <thead class="table-light">
            <tr>
                <th>Module</th>
                <th class="col-perm" title="Can View"><i class="bi bi-eye"></i> View</th>
                <th class="col-perm" title="Can Create"><i class="bi bi-plus-circle"></i> Create</th>
                <th class="col-perm" title="Can Update"><i class="bi bi-pencil"></i> Update</th>
                <th class="col-perm" title="Can Delete"><i class="bi bi-trash"></i> Delete</th>
                <th class="col-actions">Actions</th>
            </tr>
        </thead>
        <tbody id="matrixBody">
            <tr>
                <td colspan="6" class="text-center py-4">
                    <span class="spinner-border spinner-border-sm me-2"></span>Loading modules...
                </td>
            </tr>
        </tbody>
    </table>
</div>

@section Scripts {
    <script src="~/js/Utilities/tomselect-helper.js" asp-append-version="true"></script>
    <script src="~/js/Settings/Permission/RolePermissionsScript.js" asp-append-version="true"></script>
}
