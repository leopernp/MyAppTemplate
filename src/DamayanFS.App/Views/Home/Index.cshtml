@model DamayanFS.App.ViewModels.DashboardViewModel

@await Component.InvokeAsync("PageHeader", Model.PageHeader)

<div class="container-fluid py-4">
    <div class="row g-4 mb-4">
        <div class="col-12">
            <h2 class="h4 fw-bold mb-1">Welcome back, @Model.UserName</h2>
            <p class="text-muted small">Here's what is happening with your projects today.</p>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-3">
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-primary-subtle text-primary p-3 me-3">
                        <i class="bi bi-kanban fs-4"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-0 small">Active Projects</h6>
                        <span class="h4 fw-bold">@Model.ActiveProjects</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-3">
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-warning-subtle text-warning p-3 me-3">
                        <i class="bi bi-clock-history fs-4"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-0 small">Pending Tasks</h6>
                        <span class="h4 fw-bold">@Model.PendingTasks</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-3">
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-success-subtle text-success p-3 me-3">
                        <i class="bi bi-shield-check fs-4"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-0 small">System Status</h6>
                        <span class="h4 fw-bold">@Model.SystemHealth</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white py-3 border-0">
                    <h6 class="fw-bold mb-0">Primary Workspace</h6>
                </div>
                <div class="card-body bg-light-subtle d-flex flex-column align-items-center justify-content-center text-center p-5">
                    <div class="mb-3 opacity-25">
                        <i class="bi bi-window-stack display-1"></i>
                    </div>
                    <h5>No Active View Selected</h5>
                    <p class="text-muted small px-5">Select a project from the sidebar or use the quick-action menu to populate this workspace.</p>
                    <button class="btn btn-primary btn-sm px-4">Create New Project</button>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white py-3 border-0">
                    <h6 class="fw-bold mb-0">Recent Activity</h6>
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush">
                        @* @foreach (var activity in Model.RecentActivities)
                        {
                            <li class="list-group-item border-0 py-3 d-flex align-items-start">
                                <i class="bi @activity.Icon text-muted me-3 mt-1"></i>
                                <div>
                                    <div class="small fw-bold">@activity.Title</div>
                                    <div class="text-muted" style="font-size: 0.75rem;">@activity.Time</div>
                                </div>
                            </li>
                        } *@
                    </ul>
                </div>
                <div class="card-footer bg-white text-center border-0 py-3">
                    <a href="#" class="small text-decoration-none">View All Activity</a>
                </div>
            </div>

            <div class="card border-0 shadow-sm bg-dark text-white">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-3">Resources</h6>
                    <div class="d-grid gap-2">
                        <a href="#" class="btn btn-outline-light btn-sm text-start border-secondary">
                            <i class="bi bi-book me-2"></i> Documentation
                        </a>
                        <a asp-controller="Tools" asp-action="Index" class="btn btn-outline-light btn-sm text-start border-secondary">
                            <i class="bi bi-terminal me-2"></i> Maintenance Hub
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
