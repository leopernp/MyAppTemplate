@model MyAppTemplate.App.ViewModels.Tools.ToolLogViewModel

@await Component.InvokeAsync("PageHeader", Model.PageHeader)

<div class="container-fluid">
    <div class="row g-3">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm overflow-hidden h-100">
                <div class="card-header bg-body-tertiary border-bottom py-2 d-flex align-items-center">
                    <i class="bi bi-folder2-open me-2 text-primary"></i>
                    <span class="fw-bold small text-uppercase">Log Files</span>
                </div>
                <div id="file-list" class="list-group list-group-flush log-sidebar-scroll">
                    <div class="p-3 text-center text-muted small">Loading files...</div>
                </div>
            </div>
        </div>

        <div class="col-md-9">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-dark d-flex justify-content-between align-items-center py-1 ps-3 pe-2">
                    <div class="d-flex align-items-center">
                        <div class="terminal-dots me-3 d-none d-sm-flex">
                            <span class="dot bg-danger"></span>
                            <span class="dot bg-warning"></span>
                            <span class="dot bg-success"></span>
                        </div>
                        <span id="current-file-name" class="font-monospace small text-white-50">Select a file...</span>
                    </div>
                    <button onclick="refreshCurrentLog()" class="btn btn-link btn-sm text-white-50 text-decoration-none hover-white">
                        <i class="bi bi-arrow-clockwise me-1"></i> Refresh
                    </button>
                </div>
                <pre id="log-content" class="log-display mb-0">Please select a log file from the left panel.</pre>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/pages.systemlogviewer.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/Tools/LogViewerScript.js" asp-append-version="true"></script>
}