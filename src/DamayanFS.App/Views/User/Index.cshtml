@model DamayanFS.App.ViewModels.User.UserIndexViewModel

@await Component.InvokeAsync("PageHeader", Model.PageHeader)

<div id="pagePermissions"
     data-can-create="@Model.CanCreate.ToString().ToLower()"
     data-can-update="@Model.CanUpdate.ToString().ToLower()"
     data-can-delete="@Model.CanDelete.ToString().ToLower()"
     style="display:none;"></div>

<div class="d-flex justify-content-between align-items-center mb-2">
    <button type="button" class="btn btn-sm btn-outline-secondary" id="btnRefreshUsers">
        <i class="bi bi-arrow-clockwise"></i> Refresh
    </button>
    <div class="input-group input-group-sm" style="max-width: 260px;">
        <span class="input-group-text border-end-0 bg-transparent"><i class="bi bi-search text-muted"></i></span>
        <input type="text" class="form-control border-start-0" id="tableUsersSearch" placeholder="Search users...">
    </div>
</div>

<div class="table-responsive">
    <table class="table table-hover" id="tableUsers">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Active</th>
                <th>Created By</th>
                <th>Created At</th>
                <th>Modified By</th>
                <th>Modified At</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody></tbody>
    </table>
</div>

<!-- Edit User Modal -->
<div class="modal fade" id="modalEditUser" tabindex="-1" aria-labelledby="modalEditUserLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title" id="modalEditUserLabel">Edit User</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="formEditUser" novalidate>
                    <input type="hidden" asp-for="User.Id" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="User.FirstName" class="form-label form-label-sm"></label>
                            <input asp-for="User.FirstName" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="User.LastName" class="form-label form-label-sm"></label>
                            <input asp-for="User.LastName" class="form-control form-control-sm" />
                        </div>
                        <div class="col-12">
                            <label asp-for="User.MiddleName" class="form-label form-label-sm"></label>
                            <input asp-for="User.MiddleName" class="form-control form-control-sm" />
                        </div>
                        <div class="col-12">
                            <label asp-for="User.Username" class="form-label form-label-sm"></label>
                            <input asp-for="User.Username" class="form-control form-control-sm" />
                        </div>
                        <div class="col-12">
                            <label asp-for="User.Email" class="form-label form-label-sm"></label>
                            <input asp-for="User.Email" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-8">
                            <label asp-for="User.RoleId" class="form-label form-label-sm"></label>
                            <select asp-for="User.RoleId" class="form-select form-select-sm">
                            </select>
                        </div>
                        <div class="col-md-4 d-flex align-items-end pb-1">
                            <div class="form-check form-switch">
                                <input asp-for="User.IsActive" class="form-check-input" role="switch" />
                                <label asp-for="User.IsActive" class="form-check-label small"></label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-sm btn-primary" id="btnSaveUser">Save Changes</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/Utilities/datatables-helper.js" asp-append-version="true"></script>
    <script src="~/js/Utilities/tomselect-helper.js" asp-append-version="true"></script>

    <script src="~/js/Settings/User/UserIndexScript.js" asp-append-version="true"></script>
}
