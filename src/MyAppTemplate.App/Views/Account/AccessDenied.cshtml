@{
    Layout = null;
    ViewData["Title"] = "Access Denied";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — MyAppTemplate</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/app.error.css" />
</head>
<body class="error-body">

    <div class="error-wrapper">
        <div class="error-card">

            <!-- Icon -->
            <div class="error-icon error-icon--warning">
                <i class="bi bi-shield-lock"></i>
            </div>

            <!-- Code -->
            <div class="error-code">403</div>

            <!-- Title -->
            <div class="error-title">Access Denied</div>

            <!-- Description -->
            <div class="error-description">
                You don't have permission to access this page.
                If you believe this is a mistake, please contact your administrator.
            </div>

            <!-- Actions -->
            <div class="error-actions">
                <a asp-controller="Home" asp-action="Index" class="error-btn error-btn--primary">
                    <i class="bi bi-house me-2"></i>Go to Dashboard
                </a>
                <a href="javascript:history.back()" class="error-btn error-btn--secondary">
                    <i class="bi bi-arrow-left me-2"></i>Go Back
                </a>
            </div>

        </div>

        <div class="error-footer">
            &copy; @DateTime.Now.Year MyAppTemplate. All rights reserved.
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Apply saved theme
        (function () {
            var t = localStorage.getItem('theme') ||
                (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
            document.documentElement.setAttribute('data-bs-theme', t);
        }());
    </script>
</body>
</html>