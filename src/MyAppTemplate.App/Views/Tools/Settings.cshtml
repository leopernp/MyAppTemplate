@model MyAppTemplate.App.ViewModels.Tools.ToolSettingsViewModel

@await Component.InvokeAsync("PageHeader", Model.PageHeader)

<div class="container-fluid">
    <div class="row g-3">
        <div class="col-md-3">
            <div class="p-2 border-bottom small fw-bold text-muted text-uppercase bg-body-secondary">
                <i class="bi bi-history me-1"></i> Version History
            </div>
            <div id="backup-list" class="list-group list-group-flush settings-sidebar-scroll">
            </div>
        </div>

        <div class="col-md-9">
            <div class="card border-0 shadow-sm overflow-hidden">
                <div class="card-header bg-dark d-flex justify-content-between align-items-center py-2 ps-3 pe-2">
                    <div class="d-flex align-items-center">
                        <div class="terminal-dots me-3 d-none d-sm-flex">
                            <span class="dot bg-danger"></span>
                            <span class="dot bg-warning"></span>
                            <span class="dot bg-success"></span>
                        </div>
                        <span class="font-monospace small text-white-50">CONFIGURATION MANAGER</span>
                    </div>
                    <div id="save-status"></div>
                </div>
                <textarea id="json-editor" class="form-control font-monospace p-4"
                          placeholder="Loading configuration..."
                          style="height: calc(100vh - 300px); resize: none; border: none;"></textarea>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/pages.tools-settings.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/Tools/SettingsScript.js" asp-append-version="true"></script>
}