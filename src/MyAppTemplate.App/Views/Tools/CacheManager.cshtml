@model MyAppTemplate.App.ViewModels.Tools.ToolCacheViewModel

@await Component.InvokeAsync("PageHeader", Model.PageHeader)

<div class="container-fluid">
    <div class="card border-0 shadow-sm overflow-hidden">
        @* Terminal Header matches your Migrations style *@
        <div class="card-header bg-dark d-flex justify-content-between align-items-center py-2 ps-3 pe-2">
            <div class="d-flex align-items-center">
                <div class="terminal-dots me-3 d-none d-sm-flex">
                    <span class="dot bg-danger"></span>
                    <span class="dot bg-warning"></span>
                    <span class="dot bg-success"></span>
                </div>
                <span class="font-monospace small text-white-50 text-uppercase">System Cache Registry</span>
            </div>
            <div id="cache-stats" class="small text-white-50 font-monospace">
                Initializing...
            </div>
        </div>

        <div class="row g-0">
            <div class="col-12">
                <div class="table-responsive settings-sidebar-scroll" style="min-height: 400px;">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-body-tertiary">
                            <tr class="small text-uppercase text-muted">
                                <th class="ps-4">Cache Key</th>
                                <th>Type</th>
                                <th class="text-end pe-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="cache-list" class="font-monospace">
                            @* Content loaded via JavaScript *@
                            <tr>
                                <td colspan="3" class="text-center py-5">
                                    <div class="spinner-border spinner-border-sm text-primary me-2"></div>
                                    Scanning memory...
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal -->

<div class="modal fade" id="inspectModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content bg-dark border-secondary">
            <div class="modal-header border-secondary py-2">
                <span class="text-white-50 small font-monospace text-uppercase">Cache Inspector</span>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0">
                <pre id="sql-content" class="p-4 mb-0 text-info font-monospace small" style="max-height: 500px; overflow-y: auto;"></pre>
            </div>
        </div>
    </div>
</div>

@section Styles {
    @* Reusing the same CSS to maintain terminal dot styling *@
    <link rel="stylesheet" href="~/css/pages/pages.tools-migrations.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/pages.tools-cache.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/Tools/CacheScript.js" asp-append-version="true"></script>
}