@model MyAppTemplate.App.ViewModels.Tools.ToolSystemInfoViewModel

@await Component.InvokeAsync("PageHeader", Model.PageHeader)

<div class="container-fluid">
    <div class="row g-3">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-3 bg-body-tertiary">
                <div class="d-flex align-items-center">
                    <div class="icon-circle bg-primary bg-opacity-10 p-3 me-3">
                        <i class="bi bi-cpu text-primary fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small text-uppercase fw-bold">Uptime</div>
                        <h4 id="info-uptime" class="mb-0 font-monospace">--:--:--</h4>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-3 bg-body-tertiary">
                <div class="d-flex align-items-center">
                    <div class="icon-circle bg-success bg-opacity-10 p-3 me-3">
                        <i class="bi bi-database-check text-success fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small text-uppercase fw-bold">Database</div>
                        <h4 id="info-db" class="mb-0">Checking...</h4>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-3 bg-body-tertiary">
                <div class="d-flex align-items-center">
                    <div class="icon-circle bg-info bg-opacity-10 p-3 me-3">
                        <i class="bi bi-memory text-info fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small text-uppercase fw-bold">Memory</div>
                        <h4 id="info-memory" class="mb-0 font-monospace">0 MB</h4>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card border-0 shadow-sm overflow-hidden">
                <div class="card-header bg-dark py-2 d-flex justify-content-between align-items-center">
                    <span class="small fw-bold text-white-50 text-uppercase">Environment Details</span>

                    <div class="form-check form-switch m-0 d-flex align-items-center">
                        <input class="form-check-input bg-secondary border-0" type="checkbox" id="liveModeToggle" style="cursor:pointer;">
                        <label class="form-check-label small fw-bold ms-2 text-white-50" for="liveModeToggle" id="liveStatusLabel">
                            LIVE MODE
                        </label>
                    </div>
                </div>
                <table class="table table-hover mb-0 align-middle">
                    <tbody id="info-table-body">
                        <tr><td class="ps-4" width="30%">Environment</td><td id="env-val" class="fw-bold text-primary">--</td></tr>
                        <tr><td class="ps-4">Operating System</td><td id="os-val">--</td></tr>
                        <tr><td class="ps-4">Runtime Framework</td><td id="frame-val">--</td></tr>
                        <tr><td class="ps-4">CPU Core Count</td><td id="cpu-val">--</td></tr>
                        <tr><td class="ps-4">Server Local Time</td><td id="time-val" class="font-monospace">--</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/pages.tools-systeminfo.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/Tools/SystemInfoscript.js" asp-append-version="true"></script>
}